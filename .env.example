# Database Configuration
DB_USER=postgres
DB_PASSWORD=aegis_secure_password_change_me
DB_NAME=aegis_gateway

# pgAdmin Configuration
PGADMIN_EMAIL=admin@aegis.local
PGADMIN_PASSWORD=pgadmin_password

# Grafana Configuration
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_password

# Logging
RUST_LOG=info

# Scheduler Configuration
SCHEDULER_NODE_ID=node-1
SCHEDULER_CLUSTER_NODES=scheduler:50051

# LLM Backend Configuration
# Multi-backend support with automatic fallback chain:
# 1. vLLM (heavy models, GPU recommended)
# 2. llama.cpp (lightweight C++ models, CPU-friendly)
# 3. Ollama (Go-based, very lightweight)
# 4. HuggingFace Inference API (cloud-based, no setup required)

VLLM_ENDPOINT=http://vllm:8000
LLAMACPP_ENDPOINT=http://localhost:8001
CUDA_DEVICES=0

# HuggingFace Inference API Configuration (optional)
# Get your API key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_api_key_here
HUGGINGFACE_ENDPOINT=https://api-inference.huggingface.co/models

# Redis Configuration
REDIS_URL=redis://redis:6379

# Gateway Configuration
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_WORKERS=4

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
