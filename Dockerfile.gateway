# Multi-stage build for AEGIS Gateway
FROM rust:latest as builder

WORKDIR /build

# Install protobuf compiler
RUN apt-get update && apt-get install -y protobuf-compiler && rm -rf /var/lib/apt/lists/*

# Reduce parallel build jobs for Windows Docker Desktop stability
ENV CARGO_BUILD_JOBS=2

# Copy workspace
COPY . .

# Build in release mode with reduced parallelism
RUN cargo build --release -p aegis-gateway -j 2

# Runtime stage
FROM debian:bookworm-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    postgresql-client \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy binary from builder
COPY --from=builder /build/target/release/gateway /app/gateway

# Create non-root user
RUN useradd -m -u 1000 aegis && chown -R aegis:aegis /app
USER aegis

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health/ready || exit 1

# Expose port
EXPOSE 8080

# Run gateway
CMD ["/app/gateway"]
